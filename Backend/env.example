DEEPSEEK_API_KEY="your-deepseek-api-key"
GEMINI_API_KEY="your-gemini-api-key"
GROQ_API_KEY="your-groq-api-key"

# Gmail OAuth Configuration (Optional)
# Get these from: https://console.cloud.google.com
GMAIL_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GMAIL_CLIENT_SECRET="your-google-client-secret"
GMAIL_REDIRECT_URI="http://localhost:8000/api/v1/auth/gmail/callback"

# Encryption key for storing tokens
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY="your-encryption-key"

# Email Sync Configuration
EMAIL_SYNC_INTERVAL_MINUTES=15
EMAIL_FETCH_LIMIT=20
EMAIL_RETENTION_DAYS=30

# Database URL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cyberrakshak"

# LLM API Keys
MISTRAL_API_KEY="your-mistral-api-key"

